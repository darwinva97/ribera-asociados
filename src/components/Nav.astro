---
const path = Astro.url.pathname;
const isActive = (href: string) => {
  if (href === '/') return path === '/' || path === '';
  return path === href || path === href + '/' || path.startsWith(href + '/');
};
const links = [
  { href: '/', label: 'Inicio' },
  { href: '/servicios', label: 'Servicios' },
  { href: '/proyectos', label: 'Proyectos' },
  { href: '/financiamiento', label: 'Financiamiento' },
  { href: '/contacto', label: 'Contacto' },
];
---

<header class="nav">
  <div class="nav-inner">
    <a href="/" class="brand" aria-label="Ribera y Asociados, Inicio">
      <span class="brand-mark">Ribera</span>
      <span class="brand-amp">&amp;</span>
      <span class="brand-mark">Asociados</span>
    </a>
    <nav aria-label="Principal">
      <ul class="nav-list">
        {links.map(l => (
          <li>
            <a href={l.href} class:list={["nav-link", isActive(l.href) && "is-active"]}>
              {l.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(251, 249, 244, 0.96);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--navy-line);
  }
  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 18px 28px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }
  .brand {
    font-family: var(--serif);
    color: var(--navy);
    font-size: 1.2rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    display: flex;
    align-items: baseline;
    gap: 6px;
    line-height: 1;
  }
  .brand:hover { color: var(--navy); }
  .brand-mark { color: var(--navy); }
  .brand-amp {
    color: var(--brass);
    font-style: italic;
    font-family: var(--serif);
    font-size: 1.15rem;
  }
  .nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 30px;
    align-items: center;
  }
  .nav-link {
    font-family: var(--sans);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--body);
    padding: 6px 2px;
    position: relative;
    transition: color .2s ease;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;
    height: 1px;
    background: var(--brass);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform .25s ease;
  }
  .nav-link:hover { color: var(--brass); }
  .nav-link:hover::after { transform: scaleX(1); }
  .nav-link.is-active { color: var(--navy); }
  .nav-link.is-active::after { transform: scaleX(1); }

  @media (max-width: 900px) {
    .nav-inner { flex-direction: column; gap: 14px; padding: 14px 20px; }
    .nav-list { flex-wrap: wrap; gap: 16px; justify-content: center; }
    .nav-link { font-size: 0.66rem; }
  }
</style>
