---
interface Props {
  message?: string;
}
const { message = 'Buenas tardes. Quisiera coordinar una cita con el estudio Ribera & Asociados.' } = Astro.props;
const href = `https://wa.me/51999888777?text=${encodeURIComponent(message)}`;
---

<a class="wa" href={href} target="_blank" rel="noopener" aria-label="Contactar por WhatsApp">
  <span class="wa-pulse" aria-hidden="true"></span>
  <svg viewBox="0 0 32 32" width="22" height="22" fill="currentColor" aria-hidden="true">
    <path d="M19.11 17.21c-.3-.15-1.77-.87-2.04-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.15-1.26-.46-2.4-1.48-.89-.79-1.49-1.77-1.66-2.07-.17-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.67-1.62-.92-2.21-.24-.58-.49-.5-.67-.51l-.57-.01c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.49 0 1.47 1.06 2.89 1.21 3.09.15.2 2.09 3.2 5.07 4.49.71.3 1.26.49 1.69.62.71.23 1.36.2 1.87.12.57-.09 1.77-.72 2.02-1.42.25-.7.25-1.29.17-1.42-.07-.13-.27-.2-.57-.35zM16.05 27.5c-1.86 0-3.69-.5-5.3-1.45l-.38-.23-3.94 1.03 1.05-3.84-.25-.4a10.5 10.5 0 0 1-1.61-5.61c0-5.8 4.72-10.52 10.52-10.52 2.81 0 5.45 1.1 7.43 3.08a10.43 10.43 0 0 1 3.09 7.44c-.01 5.8-4.73 10.5-10.61 10.5zm8.94-19.44A12.43 12.43 0 0 0 16.05 4C9.16 4 3.55 9.6 3.55 16.5c0 2.21.58 4.36 1.67 6.26L3.5 29l6.43-1.68a12.46 12.46 0 0 0 6.12 1.56h.01c6.9 0 12.51-5.6 12.52-12.5 0-3.34-1.3-6.48-3.66-8.85z"/>
  </svg>
  <span class="wa-label">WhatsApp</span>
</a>

<style>
  .wa {
    position: fixed;
    right: 24px;
    bottom: 24px;
    z-index: 90;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 13px 20px 13px 16px;
    background: #25d366;
    color: #fff;
    border-radius: 999px;
    font-family: var(--sans);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    box-shadow: 0 6px 22px rgba(15, 30, 58, 0.14), 0 2px 6px rgba(15, 30, 58, 0.08);
    transition: transform .25s ease, box-shadow .25s ease, background .25s ease;
  }
  .wa:hover {
    color: #fff;
    transform: translateY(-2px);
    background: #20bd5b;
    box-shadow: 0 10px 28px rgba(37, 211, 102, 0.34);
  }
  .wa-pulse {
    position: absolute;
    inset: 0;
    border-radius: 999px;
    background: #25d366;
    z-index: -1;
    animation: wa-pulse 2.6s ease-out infinite;
    opacity: 0.5;
  }
  @keyframes wa-pulse {
    0% { transform: scale(1); opacity: 0.5; }
    70% { transform: scale(1.18); opacity: 0; }
    100% { transform: scale(1.18); opacity: 0; }
  }
  @media (max-width: 600px) {
    .wa-label { display: none; }
    .wa { padding: 14px; }
  }
</style>
